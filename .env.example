# Bianca Markets — environment config
# Copy to .env and fill in. .env is gitignored — NEVER commit it.

# ── Network ────────────────────────────────────────────────────────────────
# "sepolia" (Celo Sepolia testnet, chain id 11142220) or "mainnet" (42220).
# Note: Alfajores was sunset after Celo's L2 migration; Sepolia replaces it.
CELO_NETWORK=sepolia

# When true, the agent never signs or sends swap transactions
DRY_RUN=true

# Wallet private key (0x-prefixed, 64 hex chars). Paste it here yourself —
# never into chat. Used to SIGN x402 payments (buyer side, gasless stablecoin
# spend) and, from Phase 3, swap transactions.
PRIVATE_KEY=

# ── Upstream data APIs (proxy fetches these; mock fallback if missing) ─────
# Macro calendar needs no key (TradingView with Forex Factory fallback);
# Finnhub was dropped 2026-07-09 — its calendar endpoint is premium-only.
TWELVEDATA_API_KEY=
NEWSAPI_API_KEY=

# ── x402 paid data proxy ───────────────────────────────────────────────────
# Seller side (data proxy). PAY_TO is a public address — receiving needs NO
# private key. Use a SEPARATE wallet you own, NOT the agent's wallet (the
# agent is the buyer; paying its own address makes every payment a
# self-transfer). The facilitator API key (for settling payments on-chain) is
# created at https://x402.celo.org by connecting your wallet and signing a
# message in the browser, then topping up settlement credits with USDC.
X402_PAY_TO=0xYourSeparateRevenueWalletAddress
X402_FACILITATOR_API_KEY=
# Price per data pull in USD (settled in X402_ASSET, default USDC)
X402_PRICE_USD=0.005
# X402_ASSET=USDC
# DATA_PROXY_PORT=4021
# DATA_PROXY_PUBLIC_URL=http://localhost:4021

# Buyer side (agent). When set together with PRIVATE_KEY, the agent buys its
# market data through the proxy with real x402 micropayments.
# DATA_PROXY_URL=http://localhost:4021

# ── Phase 3: swap engine (Mento broker, ERC-8021 attribution) ──────────────
# Risk controls — enforced before ANY swap, logged even in dry run.
# MAX_POSITION_USD=5
# DAILY_LOSS_LIMIT_USD=10
# SWAP_SLIPPAGE_BPS=50
# Comma-separated list; the Celo Builders-assigned tag (celo_ + 12 hex,
# from registration) must be included or leaderboards will not credit swaps.
# ATTRIBUTION_CODE=bianca_markets,celo_<assigned-tag>
# RISK_STATE_FILE=.state/risk-sepolia.json

# ── Optional RPC overrides (defaults: Forno public endpoints) ──────────────
# Backup is tried automatically when the primary fails (viem fallback);
# mainnet default backup is https://1rpc.io/celo, sepolia has none.
# CELO_MAINNET_RPC=https://forno.celo.org
# CELO_MAINNET_RPC_BACKUP=https://1rpc.io/celo
# CELO_SEPOLIA_RPC_BACKUP=
# CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
